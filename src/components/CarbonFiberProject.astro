---
import { withBase } from '../lib/assets';
import { entrySlug } from '../lib/entries';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

const { project, relatedPeople, relatedPublications } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{project.data.title} — RAMSLAB</title>
  <style>
    :root {
      --bg: #050505ff;
      --text: #ffffff;
      --text-muted: #a0a0a0;
      --font-tech: var(--font-sans);
    }
    body, html {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-tech);
      scroll-behavior: smooth;
      overflow-x: hidden;
    }
    
    .carbon-bg {
      background: 
        linear-gradient(27deg, #ede1e1ff 5px, transparent 5px) 0 5px,
        linear-gradient(207deg, #efe8e8ff 5px, transparent 5px) 10px 0px,
        linear-gradient(27deg, #ede1e1ff 5px, transparent 5px) 0px 10px,
        linear-gradient(207deg, #efe8e8ff 5px, transparent 5px) 10px 5px,
        linear-gradient(90deg, #ede1e1ff 10px, transparent 10px),
        linear-gradient(#ede1e1ff 25%, #ede1e1ff 25%, #ede1e1ff 50%, transparent 50%, transparent 75%, #ede1e1ff 75%, #ede1e1ff 100%),
        #ede1e1ff;
      background-size: 20px 20px;
    }

    section {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
    }

    .container {
      width: min(1200px, 90vw);
      margin: 0 auto;
    }

    .hero {
      align-items: center;
      text-align: center;
      overflow: hidden;
    }
    .hero-video-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: radial-gradient(circle at 50% 50%, #1a1a1a 0%, #050505 100%);
      z-index: 1;
    }
    .fluid-shape {
      position: absolute;
      width: 60vw;
      height: 60vw;
      background: radial-gradient(circle, rgba(50,50,50,0.4) 0%, transparent 60%);
      border-radius: 50%;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      animation: pulse 10s infinite alternate ease-in-out;
      filter: blur(40px);
    }
    @keyframes pulse {
      0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
      100% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.8; }
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .hero-title {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 1rem;
      text-transform: uppercase;
    }
    .hero-subtitle {
      font-size: 1.1rem;
      color: var(--text-muted);
      font-weight: 300;
      max-width: 600px;
      margin: 0 auto;
      letter-spacing: 0.05em;
    }

    .vision {
      background: #000;
      text-align: center;
    }
    .vision-text {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 400;
      line-height: 1.4;
      max-width: 900px;
      margin: 0 auto;
      color: #fff;
    }

    .module-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      padding: 4rem 0;
    }
    @media (max-width: 768px) {
      .module-split { grid-template-columns: 1fr; }
    }
    .module-text h2 {
      font-size: 1.8rem;
      font-weight: 300;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .module-text p {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }
    .module-visual {
      aspect-ratio: 1;
      background: linear-gradient(135deg, #111, #222);
      border: 1px solid #333;
      position: relative;
      overflow: hidden;
    }
    .module-visual::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background-image: 
        linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
      background-size: 20px 20px;
      transform: perspective(500px) rotateX(45deg);
    }

    .recap {
      background: #050505;
      padding: 6rem 0;
      min-height: auto;
    }
    .recap-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
    @media (max-width: 900px) {
      .recap-grid { grid-template-columns: 1fr; }
    }
    .recap-col h3 {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border-bottom: 1px solid #333;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
      color: var(--text-muted);
    }
    .recap-item {
      margin-bottom: 1.5rem;
    }
    .recap-item-title {
      font-size: 1rem;
      margin-bottom: 0.5rem;
      color: #fff;
    }
    .recap-item-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
      line-height: 1.5;
    }
    .recap a {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 4px;
    }
    .recap a:hover {
      color: #fff;
    }
  </style>
</head>
<body class="carbon-bg project-page-layout">
  <Header />

  <section class="hero">
    <div class="hero-video-bg">
      <div class="fluid-shape"></div>
    </div>
    <div class="container hero-content">
      <h1 class="hero-title">{project.data.title}</h1>
      <p class="hero-subtitle">Algorithmic weaving and predictive modeling of high-performance composites</p>
    </div>
  </section>

  <section class="vision">
    <div class="container">
      <h2 class="vision-text">Engineering the future of lightweight structures through advanced composites and algorithmic design.</h2>
    </div>
  </section>

  <section class="module">
    <div class="container module-split">
      <div class="module-text">
        <h2>Structural Analysis</h2>
        <p>By leveraging digital twin technologies and finite element analysis, we predict the behavior of complex carbon fiber weaves under extreme loads. This allows for rapid iteration without the need for physical prototypes.</p>
        <p>Our approach minimizes material waste and optimizes the strength-to-weight ratio for aerospace and automotive applications.</p>
      </div>
      <div class="module-visual">
        <video 
          src={withBase('/videos/projects/CF.mp4')} 
          autoplay 
          loop 
          muted 
          playsinline 
          style="width: 100%; height: 100%; object-fit: cover; position: relative; z-index: 1;"
        ></video>
      </div>
    </div>
  </section>

  <section class="recap">
    <div class="container recap-grid">
      <div class="recap-col">
        <h3>Project Scope</h3>
        <div class="recap-item">
          <p class="recap-item-meta">{project.data.excerpt}</p>
        </div>
      </div>
      
      <div class="recap-col">
        <h3>Team</h3>
        {relatedPeople.map((person) => (
          <div class="recap-item">
            <div class="recap-item-title">{person.data.name}</div>
            <div class="recap-item-meta">{person.data.role}</div>
          </div>
        ))}
      </div>

      <div class="recap-col">
        <h3>Publications</h3>
        {relatedPublications.map((pub) => (
          <div class="recap-item">
            <div class="recap-item-title">
              {pub.data.url ? <a href={withBase(pub.data.url)}>{pub.data.title}</a> : pub.data.title}
            </div>
            <div class="recap-item-meta">{pub.data.venue}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</body>
</html>

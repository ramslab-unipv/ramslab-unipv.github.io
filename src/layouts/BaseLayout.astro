---
import '../styles/global.css';
import site from '../content/settings/site.json';
import { withBase } from '../lib/assets';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.siteTitle, description = site.siteDescription } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={withBase('/images/brand/ramslab-icon-black.png')} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

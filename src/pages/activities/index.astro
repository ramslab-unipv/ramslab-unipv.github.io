---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/assets';
import { entrySlug } from '../../lib/entries';

const getActivityHref = (activityId: string) => {
  const slug = entrySlug(activityId);
  if (slug === 'demetra-nodes') return withBase('/activities/demetra/');
  if (slug === 'air-flow-dynamic') return withBase('/activities/air-flow-dynamic/');
  if (slug === 'robotic-liquid-handling') return withBase('/activities/robotic-liquid-handling/');
  return null;
};

const activities = (await getCollection('activities')).sort((a, b) => {
  const hrefA = getActivityHref(a.id);
  const hrefB = getActivityHref(b.id);
  
  if (!!hrefA !== !!hrefB) return hrefA ? -1 : 1;
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});
---

<BaseLayout title="Activities — RAMSLAB">
  <Header />
  <main class="projects-page-main">
    <section class="projects-header-section">
      <div class="projects-header-container">
        <div class="projects-header-content">
          <h1 class="projects-title-big">Activities</h1>
        </div>
      </div>
    </section>

    <section class="projects-list-section">
      <div class="activities-grid-container">
        {activities.map((activity) => {
          const href = getActivityHref(activity.id);
          return (
          <article class={`activity-card ${href ? 'activity-card-clickable' : 'activity-card-disabled'}`}>
            {activity.data.cover && (
              href ? (
                <a href={href} class="activity-card-image-link">
                  <img 
                    src={withBase(activity.data.cover)} 
                    alt={activity.data.title} 
                    class={activity.data.coverFit === 'contain' ? 'fit-contain' : 'fit-cover'}
                    loading="lazy"
                  />
                </a>
              ) : (
                <div class="activity-card-image-link">
                  <img 
                    src={withBase(activity.data.cover)} 
                    alt={activity.data.title} 
                    class={activity.data.coverFit === 'contain' ? 'fit-contain' : 'fit-cover'}
                    loading="lazy"
                  />
                </div>
              )
            )}
            <div class="activity-card-info">
              <div class="activity-card-meta">
                <span>{activity.data.year ? String(activity.data.year) : 'Undated'}</span>
                <span>·</span>
                <span>{activity.data.status ?? 'Activity'}</span>
              </div>
              <h2 class="activity-card-title">
                {href ? <a href={href}>{activity.data.title}</a> : <span>{activity.data.title}</span>}
              </h2>
              {activity.data.excerpt && <p class="activity-card-excerpt">{activity.data.excerpt}</p>}
            </div>
          </article>
        )})}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

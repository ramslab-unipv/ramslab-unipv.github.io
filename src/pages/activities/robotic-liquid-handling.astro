---
import ProjectImmersiveLayout from '../../components/ProjectImmersiveLayout.astro';
import { withBase } from '../../lib/assets';

const project = {
  title: "ROBOTIC LIQUID HANDLING",
  subtitle: "Robots move containers, not fluids. We give them the vision to measure liquid dynamics and the algorithms to optimize transport, suppress sloshing, or enforce controlled mixing.",
  accentColor: "#f97316", // Orange
  description: `Industrial robots manipulate containers, not liquids. The fluid inside is typically treated as an unpredictable disturbance, leading to sluggish, conservative trajectories or uncontrolled sloshing that degrades cycle times. This research treats liquid dynamics differently: as a physical system to be measured, modeled, and actively controlled.

Using a vision-based approach, the robot performs brief exploratory excitations to characterize the free-surface response of an unknown liquid. The extracted dynamic signature directly feeds numerical optimization algorithms to generate task-specific trajectories. 

Motion is mathematically tailored to the fluid's physics. The objective can switch seamlessly from minimizing transfer time under strict sloshing constraints, to eliminating residual vibrations upon arrival, to actively exploiting resonance for in-transit mixing.

By linking vision-based measurement with trajectory optimization, we eliminate trial-and-error programming. The result is an adaptive robotic system that observes the fluid, extracts its dominant dynamics, and executes the optimal motion strategy—regardless of the liquid or container.`,
  publications: [
    {
      title: "A Vision-Based Strategy for Adaptive Robotic Liquid Handling and Sloshing Reduction",
      url: "#",
      authors: "RAMSLAB Research Group",
      venue: "IEEE International Conference on Robotics and Automation (ICRA), 2026"
    },
    {
      title: "Numerical Trajectory Optimization for Controlled Mixing in Automated Laboratory Systems",
      url: "#",
      authors: "RAMSLAB Research Group",
      venue: "Journal of Pharmaceutical Automation, 2026"
    },
    {
      title: "Dynamic Modeling of Liquid-Container Systems for Industrial Applications",
      url: "#",
      authors: "RAMSLAB Research Group",
      venue: "International Symposium on Experimental Robotics (ISER), 2025"
    }
  ],
  funding: "This research was funded by MED4REPAIR - Smart advanced medical devices for tissue repair “Collabora e Innova” , R1.2024.0005575 27/11/2024, PR FESR 2021–2027 Regione Lombardia (Project ID 6064179)."
};
---

<ProjectImmersiveLayout
  title={project.title}
  subtitle={project.subtitle}
  accentColor={project.accentColor}
  heroVideo={withBase('/videos/projects/Media1.mp4')}
  sectionA={{
    label: "MOVING LIQUIDS IS NOT JUST MOVING CONTAINERS",
    text: "Liquids are not rigid bodies. They oscillate, resonate, and spill. Yet, industrial robots still move them blindly. We give robots the ability to measure and anticipate fluid dynamics, turning chaotic sloshing into a controlled variable.",
    sideVideoWide: withBase('/videos/projects/Media2.mp4'),
  }}
  sectionB={{
    label: "CHARACTERIZE BEFORE OPTIMIZING",
    text: "Forget slow manual tuning. When handling an unknown liquid, the robot performs a rapid set of exploratory motions. Through vision-based observation, it identifies the system's dynamic signature in seconds, extracting the exact parameters needed for optimization.",
    sideImage: withBase('/images/projects/Picture2.png'),
  }}
  sectionC={{
    label: "OPTIMIZE THE MOTION FOR THE TASK",
    text: "With the dynamics mapped, motion is no longer guesswork. Trajectories are numerically optimized to push physical limits: minimize transfer time without spilling, cancel out residual vibrations at the target, or deliberately excite resonance for controlled mixing.",
    sideImage: withBase('/images/projects/Picture3.png'),
  }}
  sectionD={{
    label: "FROM SAFE TRANSFER TO CONTROLLED MIXING",
    text: "Sloshing is treated as a defect, but it is just energy. We use it. While most approaches try to suppress fluid motion, we actively shape it. The same robotic trajectory that guarantees zero-spill transport can be re-engineered to induce vigorous, controlled mixing.",
    sideVideoWide: withBase('/videos/projects/Media1.mp4'),
  }}
  sectionE={{
    label: "TOWARDS ADAPTIVE LIQUID-HANDLING ROBOTS",
    text: "Hardcoded trajectories are obsolete. By integrating vision, dynamic modeling, and optimization, we build adaptive liquid-handling systems. The robot observes, models the physics, and computes the optimal path—regardless of the container or the fluid.",
    sideImage: withBase('/images/projects/Picture4.png'),
  }}
  description={project.description}
  publications={project.publications}
  funding={project.funding}
  prevActivity={{ label: "Airflow Dynamics", href: withBase('/activities/air-flow-dynamic/') }}
/>

<style is:global>
  /* Shrink Picture 4 in Block 5 */
  .section:nth-of-type(6) .tech-image-container {
    max-width: 60%;
    margin: 0 auto;
  }
</style>

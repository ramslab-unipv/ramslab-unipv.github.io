---
import { withBase } from '../lib/assets';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RAMSLAB — Access</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0; padding: 0;
        height: 100%;
        background: #ffffff;
        color: #111111;
        font-family: var(--font-sans);
      }

      .login-wrap {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 56px;
        padding: 40px 24px;
      }

      .login-logo img {
        height: 28px;
        width: auto;
        display: block;
      }

      .login-form {
        display: flex;
        flex-direction: column;
        gap: 0;
        width: 100%;
        max-width: 320px;
        border-top: 1px solid #d8d8d8;
      }

      .login-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 16px 0;
        border-bottom: 1px solid #d8d8d8;
      }

      .login-field label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #5f5f5f;
      }

      .login-field input {
        border: none;
        outline: none;
        background: transparent;
        font-family: inherit;
        font-size: 14px;
        color: #111111;
        padding: 0;
        width: 100%;
      }

      .login-field input::placeholder { color: #b0b0b0; }

      .login-error {
        font-size: 11px;
        color: #c00;
        min-height: 16px;
        padding-top: 10px;
        text-align: center;
        letter-spacing: 0.04em;
      }

      .login-submit {
        margin-top: 24px;
        width: 100%;
        padding: 13px;
        background: #111111;
        color: #ffffff;
        border: none;
        font-family: inherit;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.15s;
      }

      .login-submit:hover { background: #000000; }
      .login-submit:active { background: #333333; }
    </style>
  </head>
  <body>
    <div class="login-wrap">
      <div class="login-logo">
        <img src="/images/brand/ramslab-logo-header.svg" alt="RAMSLAB" />
      </div>

      <form class="login-form" id="login-form" novalidate>
        <div class="login-field">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" autocomplete="username" placeholder="username" required />
        </div>
        <div class="login-field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" autocomplete="current-password" placeholder="••••••••" required />
        </div>
        <div class="login-error" id="login-error" role="alert" aria-live="polite"></div>
        <button class="login-submit" type="submit">Enter</button>
      </form>
    </div>

    <script>
      // Redirect away if already logged in
      const existingRole = sessionStorage.getItem('ramslab_role');
      if (existingRole === 'user' || existingRole === 'admin') {
        window.location.replace('/');
      }

      // SHA-256 hashes only — plaintext password is never stored in source
      const HASHES = {
        user:  '7c213bcff9848abe8e03ae4d6a74aab83cdd382342585c94d6b7ce0aac13c5f7',
        admin: '7c213bcff9848abe8e03ae4d6a74aab83cdd382342585c94d6b7ce0aac13c5f7',
      };

      async function sha256(message) {
        const msgBuffer = new TextEncoder().encode(message);
        const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
        return Array.from(new Uint8Array(hashBuffer))
          .map(b => b.toString(16).padStart(2, '0'))
          .join('');
      }

      document.getElementById('login-form').addEventListener('submit', async function (e) {
        e.preventDefault();
        const username = document.getElementById('username').value.trim().toLowerCase();
        const passwordInput = document.getElementById('password');
        const password = passwordInput.value;
        const errorEl = document.getElementById('login-error');
        errorEl.setAttribute('tabindex', '-1');

        const expectedHash = HASHES[username];
        if (expectedHash) {
          const inputHash = await sha256(password);
          if (inputHash === expectedHash) {
            sessionStorage.setItem('ramslab_role', username);
            window.location.replace('/');
            return;
          }
        }

        passwordInput.setAttribute('aria-invalid', 'true');
        errorEl.textContent = 'Incorrect username or password.';
        passwordInput.value = '';
        errorEl.focus({ preventScroll: true }); // Give focus to the live region so it's read immediately
      });

      // Clear aria-invalid on input
      document.getElementById('password').addEventListener('input', function() {
        this.removeAttribute('aria-invalid');
        document.getElementById('login-error').textContent = '';
      });
    </script>
  </body>
</html>
